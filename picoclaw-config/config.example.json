{
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": false,
      "max_tokens": 4096,
      "temperature": 0.2,
      "max_tool_iterations": 15,
      "model_name": "minimax"
    },
    "list": [
      {
        "id": "home",
        "default": true,
        "name": "Home Assistant",
        "workspace": "~/.picoclaw/workspace-home",
        "skills": []
      },
      {
        "id": "news",
        "default": false,
        "name": "AI News Weekly",
        "workspace": "~/.picoclaw/workspace-news",
        "temperature": 0.6,
        "max_tool_iterations": 15,
        "skills": []
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "proxy": "",
      "allow_from": ["YOUR_TELEGRAM_USER_ID"]
    }
  },
  "providers": {
    "openrouter": {
      "api_key": "YOUR_OPENROUTER_API_KEY",
      "api_base": ""
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "tools": {
    "web": {
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "model_list": [
    {
      "model_name": "minimax",
      "model": "openrouter/minimax/minimax-m2.5",
      "api_key": "YOUR_OPENROUTER_API_KEY",
      "api_base": "https://openrouter.ai/api/v1"
    },
    {
      "model_name": "deepseek",
      "model": "openrouter/deepseek/deepseek-v3.2",
      "api_key": "YOUR_OPENROUTER_API_KEY",
      "api_base": "https://openrouter.ai/api/v1"
    },
    {
      "model_name": "claude",
      "model": "openrouter/anthropic/claude-sonnet-4-5",
      "api_key": "YOUR_OPENROUTER_API_KEY",
      "api_base": "https://openrouter.ai/api/v1"
    }
  ],
  "bindings": [
    {
      "agent_id": "home",
      "match": {
        "channel": "telegram",
        "peer": { "kind": "user", "id": "YOUR_USER_ID" }
      }
    },
    {
      "agent_id": "news",
      "match": {
        "channel": "telegram",
        "peer": { "kind": "group", "id": "YOUR_GROUP_ID" }
      }
    }
  ]
}
